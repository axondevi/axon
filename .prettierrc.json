{
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "overrides": [
    {
      "files": ["*.md", "*.yml", "*.yaml"],
      "options": { "printWidth": 80 }
    },
    {
      "files": ["registry/*.json"],
      "options": { "printWidth": 200 }
    }
  ]
}
