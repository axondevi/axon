{
  "slug": "together",
  "provider": "Together AI",
  "category": "LLM",
  "description": "Run open-source models (Llama 4, Qwen, DeepSeek, Mixtral, etc.) at scale.",
  "homepage": "https://docs.together.ai",
  "base_url": "https://api.together.xyz",
  "auth": { "type": "bearer" },
  "endpoints": {
    "chat": {
      "method": "POST",
      "path": "/v1/chat/completions",
      "price_usd": 0.002,
      "markup_pct": 10,
      "cache_ttl": 0,
      "notes": "Flat MVP price. Model-dependent — migrate to per-token metering."
    },
    "completions": {
      "method": "POST",
      "path": "/v1/completions",
      "price_usd": 0.002,
      "markup_pct": 10,
      "cache_ttl": 0
    },
    "embeddings": {
      "method": "POST",
      "path": "/v1/embeddings",
      "price_usd": 0.0005,
      "markup_pct": 15,
      "cache_ttl": 2592000,
      "cache_on_body": true
    }
  }
}
