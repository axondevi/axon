{
  "slug": "neynar",
  "provider": "Neynar",
  "category": "Social",
  "description": "Farcaster protocol API — read/write casts, user graph, channels.",
  "homepage": "https://docs.neynar.com",
  "base_url": "https://api.neynar.com",
  "auth": {
    "type": "header",
    "name": "x-api-key"
  },
  "endpoints": {
    "user-by-fid": {
      "method": "GET",
      "path": "/v2/farcaster/user/bulk",
      "price_usd": 0.0005,
      "markup_pct": 40,
      "cache_ttl": 3600
    },
    "casts-by-fid": {
      "method": "GET",
      "path": "/v2/farcaster/feed/user/casts",
      "price_usd": 0.001,
      "markup_pct": 40,
      "cache_ttl": 300
    }
  }
}
