{
  "slug": "alchemy",
  "provider": "Alchemy",
  "category": "Blockchain Data",
  "description": "Multichain JSON-RPC + enhanced APIs (NFTs, transfers, prices).",
  "homepage": "https://docs.alchemy.com",
  "base_url": "https://eth-mainnet.g.alchemy.com",
  "auth": { "type": "query", "name": "apiKey" },
  "endpoints": {
    "nft-by-owner": {
      "method": "GET",
      "path": "/nft/v3/:apiKey/getNFTsForOwner",
      "price_usd": 0.0002,
      "markup_pct": 25,
      "cache_ttl": 60,
      "notes": "Path template resolves apiKey from upstream key."
    },
    "token-prices": {
      "method": "POST",
      "path": "/prices/v1/:apiKey/tokens/by-symbol",
      "price_usd": 0.0005,
      "markup_pct": 20,
      "cache_ttl": 300,
      "cache_on_body": true
    }
  }
}
