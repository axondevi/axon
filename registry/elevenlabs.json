{
  "slug": "elevenlabs",
  "provider": "ElevenLabs",
  "category": "Voice",
  "description": "State-of-the-art text-to-speech and voice cloning.",
  "homepage": "https://elevenlabs.io",
  "base_url": "https://api.elevenlabs.io",
  "auth": {
    "type": "header",
    "name": "xi-api-key"
  },
  "endpoints": {
    "tts": {
      "method": "POST",
      "path": "/v1/text-to-speech/:voice_id",
      "price_usd": 0.03,
      "markup_pct": 50,
      "cache_ttl": 86400,
      "cache_on_body": true,
      "notes": "Identical (voice_id, text, settings) → same audio. 24h cache on body."
    },
    "voices": {
      "method": "GET",
      "path": "/v1/voices",
      "price_usd": 0.001,
      "markup_pct": 50,
      "cache_ttl": 3600
    }
  }
}
