{
  "slug": "hunter",
  "provider": "Hunter.io",
  "category": "Enrichment",
  "description": "Find and verify professional email addresses from a domain.",
  "homepage": "https://hunter.io/api-documentation/v2",
  "base_url": "https://api.hunter.io",
  "auth": {
    "type": "query",
    "name": "api_key"
  },
  "endpoints": {
    "domain-search": {
      "method": "GET",
      "path": "/v2/domain-search",
      "price_usd": 0.005,
      "markup_pct": 25,
      "cache_ttl": 604800,
      "notes": "7-day cache on (domain). Changes infrequently."
    },
    "email-finder": {
      "method": "GET",
      "path": "/v2/email-finder",
      "price_usd": 0.01,
      "markup_pct": 25,
      "cache_ttl": 604800
    },
    "verify": {
      "method": "GET",
      "path": "/v2/email-verifier",
      "price_usd": 0.002,
      "markup_pct": 25,
      "cache_ttl": 86400
    }
  }
}
