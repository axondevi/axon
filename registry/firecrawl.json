{
  "slug": "firecrawl",
  "provider": "Firecrawl",
  "category": "Web Intelligence",
  "description": "LLM-ready web scraping — clean markdown from any URL.",
  "homepage": "https://firecrawl.dev",
  "base_url": "https://api.firecrawl.dev",
  "auth": {
    "type": "bearer"
  },
  "endpoints": {
    "scrape": {
      "method": "POST",
      "path": "/v1/scrape",
      "price_usd": 0.005,
      "markup_pct": 50,
      "cache_ttl": 3600,
      "cache_on_body": true,
      "notes": "1h cache on (url, params) — popular pages get hit many times."
    },
    "crawl": {
      "method": "POST",
      "path": "/v1/crawl",
      "price_usd": 0.05,
      "markup_pct": 50,
      "cache_ttl": 0,
      "notes": "Crawl jobs are async — no cache."
    },
    "search": {
      "method": "POST",
      "path": "/v1/search",
      "price_usd": 0.01,
      "markup_pct": 50,
      "cache_ttl": 1800,
      "cache_on_body": true
    }
  }
}
