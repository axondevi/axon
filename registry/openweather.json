{
  "slug": "openweather",
  "provider": "OpenWeather",
  "category": "Geo & Weather",
  "description": "Current weather, forecasts, and historical data worldwide.",
  "homepage": "https://openweathermap.org/api",
  "base_url": "https://api.openweathermap.org",
  "auth": {
    "type": "query",
    "name": "appid"
  },
  "endpoints": {
    "current": {
      "method": "GET",
      "path": "/data/2.5/weather",
      "price_usd": 0.0005,
      "markup_pct": 25,
      "cache_ttl": 900,
      "notes": "15m cache on (lat,lon) — same location/time returns same data."
    },
    "forecast": {
      "method": "GET",
      "path": "/data/2.5/forecast",
      "price_usd": 0.001,
      "markup_pct": 25,
      "cache_ttl": 3600
    },
    "geocode": {
      "method": "GET",
      "path": "/geo/1.0/direct",
      "price_usd": 0.0005,
      "markup_pct": 25,
      "cache_ttl": 2592000,
      "notes": "30d cache — place→coords almost never changes."
    }
  }
}
