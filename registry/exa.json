      "method": "POST",
      "path": "/search",
      "price_usd": 0.005,
      "markup_pct": 10,
      "cache_ttl": 1800,
      "cache_on_body": true
    },
    "contents": {
      "method": "POST",
      "path": "/contents",
      "price_usd": 0.003,
      "markup_pct": 10,
      "cache_ttl": 3600,
      "cache_on_body": true
    },
    "similar": {
      "method": "POST",
      "path": "/findSimilar",
      "price_usd": 0.005,
      "markup_pct": 10,
      "cache_ttl": 3600,
      "cache_on_body": true
    }
  }
}
