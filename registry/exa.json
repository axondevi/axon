{
  "slug": "exa",
  "provider": "Exa",
  "category": "Web Intelligence",
  "description": "Neural search built for AI agents — semantic web search.",
  "homepage": "https://exa.ai",
  "base_url": "https://api.exa.ai",
  "auth": { "type": "header", "name": "x-api-key" },
