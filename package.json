{
  "name": "axon",
  "version": "0.1.0",
  "description": "Universal API gateway for autonomous agents. One endpoint, one wallet, every paid API.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/axondevi/axon.git"
  },
  "bugs": {
    "url": "https://github.com/axondevi/axon/issues"
  },
  "homepage": "https://axon-5zf.pages.dev",
  "keywords": [
    "x402",
    "ai-agents",
    "api-gateway",
    "usdc",
    "base-l2",
    "prepaid",
    "llm-tools"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "bun run src/db/seed.ts",
    "scheduler": "bun run src/scheduler.ts",
    "settle": "RUN_ON_BOOT=true EXIT_AFTER_BOOT=true bun run src/scheduler.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,json}\"",
    "verify": "bun run typecheck && bun run lint && bun run test"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@types/pdfkit": "^0.17.6",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "ioredis": "^5.4.1",
    "jose": "^6.2.3",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.0",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@turnkey/sdk-server": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.0",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "solc": "^0.8.34",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
