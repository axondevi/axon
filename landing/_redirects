# Cloudflare Pages _redirects
#
# CF Pages auto-serves matching files (index.html, stats.html, etc.) and
# automatically redirects .html → pretty URL.
#
# Rules are processed in order; first match wins.

# /agent/:slug → rewrite to /agent-runner with slug in query string.
# Using ":slug" placeholder + 200 makes CF perform an internal rewrite
# (URL stays put in the browser) instead of a 308.
/agent/:slug    /agent-runner?slug=:slug    200

# /agent-preview/:slug → preview UI ("test drive" before connecting WhatsApp).
/agent-preview/:slug    /agent-preview?slug=:slug    200

# Vertical niche pages — single template (niche.html) renders all 3 verticals
# from one config. URLs stay pretty (clinica/restaurante/loja) for SEO,
# rewrite is internal (200) so the bar shows the friendly path.
/clinica          /niche?tipo=clinica          200
/restaurante      /niche?tipo=restaurante      200
/loja             /niche?tipo=loja             200

# /personas was standalone but duplicated the "🎭 Personas" tab in /build.
# Send users there with the tab pre-selected via hash; build.html JS reads
# location.hash to switch tabs on load.
/personas         /build#personas              301

/*    /404.html    404
