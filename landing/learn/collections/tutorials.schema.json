{
  "$ref": "#/definitions/tutorials",
  "definitions": {
    "tutorials": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "subtitle": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "maxLength": 180
        },
        "category": {
          "type": "string",
          "enum": [
            "agents",
            "apis",
            "production",
            "brazil",
            "concepts",
            "integration"
          ]
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "iniciante",
            "intermediario",
            "avancado"
          ]
        },
        "lang": {
          "type": "string",
          "enum": [
            "pt-BR",
            "en"
          ],
          "default": "pt-BR"
        },
        "timeMinutes": {
          "type": "number"
        },
        "author": {
          "type": "string",
          "default": "Nexus Inovation Team"
        },
        "authorUrl": {
          "type": "string",
          "format": "uri"
        },
        "publishedAt": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "updatedAt": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "relatedTutorials": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "category",
        "difficulty",
        "timeMinutes",
        "publishedAt"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}