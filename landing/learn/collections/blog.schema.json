{
  "$ref": "#/definitions/blog",
  "definitions": {
    "blog": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "subtitle": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "maxLength": 240
        },
        "lang": {
          "type": "string",
          "enum": [
            "pt-BR",
            "en"
          ],
          "default": "pt-BR"
        },
        "category": {
          "type": "string",
          "enum": [
            "casos_de_uso",
            "tutoriais",
            "ia_para_negocio",
            "comparativos",
            "noticias"
          ]
        },
        "publishedAt": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "updatedAt": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "topicId": {
          "type": "number"
        },
        "counterpartSlug": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "authorshipMode": {
          "type": "string",
          "enum": [
            "ai-generated",
            "human",
            "hybrid"
          ],
          "default": "ai-generated"
        },
        "readMinutes": {
          "type": "number",
          "default": 5
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "category",
        "publishedAt",
        "topicId"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}