---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allGuides = (await getCollection('guides', g => !g.data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<BaseLayout
  title="Guias Conceituais — Axon Academy"
  description="Artigos conceituais sobre x402, MCP, agentes, custos e arquitetura de IA."
>
  <div class="container">
    <header class="page-header">
      <div class="ph-eyebrow">Axon Academy</div>
      <h1>Guias Conceituais</h1>
      <p>Entenda os conceitos antes de construir. x402, MCP, embeddings, tudo sem pressa.</p>
    </header>

    <div class="guide-list">
      {allGuides.map(g => (
        <a href={`/learn/guides/${g.id.replace(/\.(md|mdx)$/, '')}`} class="guide-item">
          <div class="gi-body">
            <h3>{g.data.title}</h3>
            <p>{g.data.description}</p>
            <div class="gi-meta">
              <span>⏱ {g.data.timeMinutes} min</span>
              <span>✎ {g.data.author}</span>
              {g.data.tags && g.data.tags.slice(0, 3).map(t => (
                <span class="gi-tag">#{t}</span>
              ))}
            </div>
          </div>
          <div class="gi-arrow">→</div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .page-header { margin-bottom: 3rem; }
  .ph-eyebrow {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-2);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .page-header h1 { margin: 0 0 0.75rem 0; }
  .page-header p { color: var(--text-tertiary); font-size: 1.1rem; margin: 0; }

  .guide-list { display: flex; flex-direction: column; gap: 1rem; }

  .guide-item {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }

  .guide-item:hover {
    border-color: var(--accent-1);
    text-decoration: none;
    transform: translateX(4px);
  }

  .gi-body { flex: 1; }

  .guide-item h3 {
    font-size: 1.15rem;
    margin: 0 0 0.4rem 0;
    color: var(--text-primary);
  }

  .guide-item p {
    color: var(--text-tertiary);
    margin: 0 0 0.75rem 0;
    font-size: 15px;
  }

  .gi-meta {
    display: flex;
    gap: 1rem;
    font-size: 12px;
    color: var(--text-muted);
    align-items: center;
    flex-wrap: wrap;
  }

  .gi-tag {
    font-family: var(--font-mono);
    color: var(--text-muted);
  }

  .gi-arrow {
    font-size: 1.5rem;
    color: var(--accent-1);
  }
</style>
