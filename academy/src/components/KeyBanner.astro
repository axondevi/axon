---
// Compact banner showing current Axon key + balance. Auto-hides if no key.
---

<div class="key-banner" id="key-banner" hidden>
  <div class="kb-inner">
    <div class="kb-status">
      <span class="kb-dot"></span>
      <span class="kb-text">
        <span class="kb-label">Conectado ao Axon como</span>
        <code class="kb-key"></code>
      </span>
    </div>
    <div class="kb-balance">
      <span class="kb-bal-label">Saldo:</span>
      <span class="kb-bal-value">—</span>
      <a href="https://axon-5zf.pages.dev/dashboard" class="kb-dashboard" target="_blank">
        Dashboard ↗
      </a>
      <button class="kb-logout" type="button" aria-label="Sair">✕</button>
    </div>
  </div>
</div>

<script is:inline src="/learn/axon-client.js"></script>

<script is:inline>
  (function () {
    const banner = document.getElementById('key-banner');
    if (!banner) return;

    const client = new window.AxonClient();
    const keyEl = banner.querySelector('.kb-key');
    const balEl = banner.querySelector('.kb-bal-value');
    const logoutBtn = banner.querySelector('.kb-logout');

    // Local balance state — decremented on each call-success, refreshed from API
    // only on key change, page load, or once per minute max (backup).
    let currentBalance = null;
    let lastFetch = 0;

    function render() {
      const key = client.getKey();
      if (!key) {
        banner.hidden = true;
        return;
      }
      banner.hidden = false;
      keyEl.textContent = key.slice(0, 14) + '…';
      refreshBalance(true);
    }

    function setBalance(value) {
      currentBalance = value;
      balEl.textContent = `$${value.toFixed(4)}`;
      balEl.classList.toggle('low', value < 0.01);
    }

    async function refreshBalance(force = false) {
      // Throttle: max 1 fetch per 60s unless forced
      const now = Date.now();
      if (!force && now - lastFetch < 60000) return;
      lastFetch = now;
      try {
        const { balanceUsdc } = await client.getBalance();
        setBalance(balanceUsdc);
      } catch (e) {
        if (currentBalance === null) balEl.textContent = '—';
      }
    }

    function onCall(e) {
      const detail = e.detail || {};
      const cost = parseFloat(detail.cost) || 0;
      if (currentBalance !== null && cost > 0) {
        setBalance(Math.max(0, currentBalance - cost));
      }
    }

    logoutBtn?.addEventListener('click', () => {
      if (confirm('Sair do Axon? Sua API key será removida deste browser.')) {
        client.clearKey();
      }
    });

    window.addEventListener('axon:key-change', render);
    window.addEventListener('axon:call-success', onCall);
    render();
    // Periodic reconciliation every 2 min (way under rate limit)
    setInterval(() => refreshBalance(), 120000);
  })();
</script>

<style>
  .key-banner {
    background: linear-gradient(90deg, rgba(124, 92, 255, 0.1), rgba(92, 138, 255, 0.1));
    border-bottom: 1px solid var(--border-soft);
  }

  .kb-inner {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: 0.5rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    font-size: 12.5px;
  }

  .kb-status {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .kb-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--success);
    box-shadow: 0 0 8px rgba(34, 197, 94, 0.6);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .kb-text {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .kb-label {
    color: var(--text-tertiary);
  }

  .kb-key {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent-2);
    background: transparent;
    border: none;
    padding: 0;
  }

  .kb-balance {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .kb-bal-label {
    color: var(--text-muted);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .kb-bal-value {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--success);
  }

  .kb-bal-value.low { color: var(--warning); }

  .kb-dashboard {
    color: var(--text-tertiary);
    font-size: 12px;
    text-decoration: none;
    padding: 0.2em 0.6em;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    transition: all 0.15s;
  }

  .kb-dashboard:hover {
    border-color: var(--accent-1);
    color: var(--text-primary);
    text-decoration: none;
  }

  .kb-logout {
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 14px;
    padding: 0.2em 0.5em;
    border-radius: var(--radius-sm);
    transition: all 0.15s;
  }

  .kb-logout:hover {
    color: var(--error);
    background: var(--bg-secondary);
  }

  @media (max-width: 640px) {
    .kb-inner { flex-direction: column; gap: 0.3rem; padding: 0.4rem 1rem; }
    .kb-label { display: none; }
  }
</style>
