---
/**
 * TryCall — interactive widget for making real Axon API calls
 *
 * Usage in MDX:
 *   <TryCall
 *     api="brasilapi"
 *     endpoint="cnpj/{cnpj}"
 *     paramFields={[{ name: 'cnpj', label: 'CNPJ', default: '00000000000191', placeholder: '14 dígitos' }]}
 *     description="Consultar dados de empresa brasileira"
 *   />
 */

interface ParamField {
  name: string;
  label: string;
  default?: string;
  placeholder?: string;
  type?: 'text' | 'number';
}

interface Props {
  api: string;
  endpoint: string;          // supports {name} substitution
  paramFields?: ParamField[]; // fields the user fills in (substitute into endpoint or query params)
  method?: 'GET' | 'POST';
  paramStyle?: 'path' | 'query';
  description?: string;
  title?: string;
  examples?: Array<{ label: string; values: Record<string, string> }>;
}

const {
  api,
  endpoint,
  paramFields = [],
  method = 'GET',
  paramStyle = 'path',
  description,
  title = 'Teste ao vivo',
  examples = [],
} = Astro.props;

const widgetId = 'trycall-' + Math.random().toString(36).slice(2, 10);
---

<div
  class="trycall"
  id={widgetId}
  data-api={api}
  data-endpoint={endpoint}
  data-method={method}
  data-param-style={paramStyle}
  data-params={JSON.stringify(paramFields)}
>
  <div class="tc-head">
    <div class="tc-head-left">
      <span class="tc-badge">◆ LIVE</span>
      <strong class="tc-title">{title}</strong>
    </div>
    <div class="tc-meta">
      <span class="tc-method">{method}</span>
      <code class="tc-api">{api}/{endpoint}</code>
    </div>
  </div>

  {description && <p class="tc-desc">{description}</p>}

  <!-- Auth gate (shown if no key in localStorage) -->
  <div class="tc-auth-gate" data-show="no-key">
    <div class="tc-auth-box">
      <h4>Faça signup pra rodar ao vivo</h4>
      <p>10 segundos, zero cartão, $0.50 de crédito grátis.</p>
      <div class="tc-signup-row">
        <input
          type="email"
          class="tc-input tc-email"
          placeholder="seu@email.com"
          autocomplete="email"
        />
        <button class="tc-btn tc-btn-primary tc-signup-btn" type="button">
          Signup
        </button>
      </div>
      <div class="tc-divider">ou</div>
      <div class="tc-paste-row">
        <input
          type="password"
          class="tc-input tc-paste-key"
          placeholder="Cola sua API key (ax_live_...)"
          autocomplete="off"
        />
        <button class="tc-btn tc-btn-secondary tc-paste-btn" type="button">
          Usar
        </button>
      </div>
      <div class="tc-signup-error" hidden></div>
    </div>
  </div>

  <!-- Main form (shown if has key) -->
  <div class="tc-form" data-show="has-key" hidden>
    <div class="tc-form-fields">
      {paramFields.map(f => (
        <div class="tc-field">
          <label>{f.label}</label>
          <input
            type={f.type ?? 'text'}
            class="tc-input tc-param"
            data-param-name={f.name}
            placeholder={f.placeholder ?? ''}
            value={f.default ?? ''}
          />
        </div>
      ))}

      {examples.length > 0 && (
        <div class="tc-examples">
          <span>Exemplos:</span>
          {examples.map((ex, i) => (
            <button class="tc-ex-btn" type="button" data-example={JSON.stringify(ex.values)}>
              {ex.label}
            </button>
          ))}
        </div>
      )}
    </div>

    <div class="tc-actions">
      <button class="tc-btn tc-btn-primary tc-run" type="button">
        <span class="tc-run-label">▶ Rodar ao vivo</span>
        <span class="tc-run-spinner" hidden>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.3"/>
            <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          </svg>
        </span>
      </button>

      <div class="tc-status">
        <span class="tc-balance-label">Saldo:</span>
        <span class="tc-balance-value">—</span>
      </div>
    </div>
  </div>

  <!-- Response area -->
  <div class="tc-response" hidden>
    <div class="tc-response-meta">
      <span class="tc-resp-status"></span>
      <span class="tc-resp-cost"></span>
      <span class="tc-resp-cache"></span>
      <span class="tc-resp-latency"></span>
    </div>
    <pre class="tc-resp-body"><code class="tc-resp-json"></code></pre>
  </div>

  <!-- Error -->
  <div class="tc-error" hidden>
    <div class="tc-error-msg"></div>
  </div>
</div>

<script is:inline src="/learn/axon-client.js"></script>

<script is:inline define:vars={{ widgetId }}>
  (function () {
    const root = document.getElementById(widgetId);
    if (!root) return;

    const api = root.dataset.api;
    const endpointTemplate = root.dataset.endpoint;
    const method = root.dataset.method;
    const paramStyle = root.dataset.paramStyle;
    const paramFields = JSON.parse(root.dataset.params);

    const client = new window.AxonClient();

    // ─── DOM refs ──────────────────────────────────
    const authGate = root.querySelector('[data-show="no-key"]');
    const form = root.querySelector('[data-show="has-key"]');
    const responseBox = root.querySelector('.tc-response');
    const errorBox = root.querySelector('.tc-error');
    const errorMsg = root.querySelector('.tc-error-msg');

    const emailInput = root.querySelector('.tc-email');
    const signupBtn = root.querySelector('.tc-signup-btn');
    const pasteKeyInput = root.querySelector('.tc-paste-key');
    const pasteBtn = root.querySelector('.tc-paste-btn');
    const signupError = root.querySelector('.tc-signup-error');

    const runBtn = root.querySelector('.tc-run');
    const runLabel = root.querySelector('.tc-run-label');
    const runSpinner = root.querySelector('.tc-run-spinner');
    const balanceValue = root.querySelector('.tc-balance-value');

    const respStatus = root.querySelector('.tc-resp-status');
    const respCost = root.querySelector('.tc-resp-cost');
    const respCache = root.querySelector('.tc-resp-cache');
    const respLatency = root.querySelector('.tc-resp-latency');
    const respJson = root.querySelector('.tc-resp-json');

    // ─── State render ──────────────────────────────
    let localBalance = null;
    let lastBalanceFetch = 0;

    function render() {
      const hasKey = client.hasKey();
      authGate.hidden = hasKey;
      form.hidden = !hasKey;
      if (hasKey && localBalance === null) refreshBalance();
    }

    function setBalance(value) {
      localBalance = value;
      balanceValue.textContent = `$${value.toFixed(4)}`;
      balanceValue.classList.toggle('low', value < 0.01);
    }

    async function refreshBalance() {
      // Throttle: max 1 fetch per minute
      const now = Date.now();
      if (now - lastBalanceFetch < 60000 && localBalance !== null) return;
      lastBalanceFetch = now;
      try {
        const { balanceUsdc } = await client.getBalance();
        setBalance(balanceUsdc);
      } catch (e) {
        if (localBalance === null) balanceValue.textContent = '—';
      }
    }

    // Listen for global call-success events to decrement locally (no fetch)
    window.addEventListener('axon:call-success', (e) => {
      const cost = parseFloat(e.detail?.cost) || 0;
      if (localBalance !== null && cost > 0) {
        setBalance(Math.max(0, localBalance - cost));
      }
    });

    // ─── Signup flow ───────────────────────────────
    async function handleSignup() {
      const email = emailInput.value.trim();
      if (!email || !email.includes('@')) {
        showSignupError('Digita um email válido');
        return;
      }

      signupBtn.disabled = true;
      signupBtn.textContent = 'Criando...';
      hideSignupError();

      try {
        const { key } = await client.signup(email);
        window.dispatchEvent(new CustomEvent('axon:signed-up', { detail: { email } }));
        render();
      } catch (e) {
        const msg = e.status === 409
          ? 'Esse email já tem conta. Cole sua API key abaixo.'
          : e.message || 'Erro no signup';
        showSignupError(msg);
      } finally {
        signupBtn.disabled = false;
        signupBtn.textContent = 'Signup';
      }
    }

    function handlePaste() {
      const key = pasteKeyInput.value.trim();
      if (!key.startsWith('ax_')) {
        showSignupError('Chave inválida (deve começar com ax_)');
        return;
      }
      client.setKey(key);
      render();
    }

    function showSignupError(msg) {
      signupError.textContent = msg;
      signupError.hidden = false;
    }

    function hideSignupError() {
      signupError.hidden = true;
    }

    // ─── Run flow ──────────────────────────────────
    function buildRequest() {
      const paramValues = {};
      root.querySelectorAll('.tc-param').forEach(inp => {
        paramValues[inp.dataset.paramName] = inp.value.trim();
      });

      let endpoint = endpointTemplate;
      const queryParams = {};

      for (const f of paramFields) {
        const value = paramValues[f.name] ?? f.default ?? '';
        const placeholder = `{${f.name}}`;

        if (endpoint.includes(placeholder)) {
          endpoint = endpoint.replace(placeholder, encodeURIComponent(value.replace(/[^0-9a-zA-Z-_.]/g, '')));
        } else if (paramStyle === 'query') {
          queryParams[f.name] = value;
        }
      }

      return { endpoint, queryParams };
    }

    async function handleRun() {
      runBtn.disabled = true;
      runLabel.hidden = true;
      runSpinner.hidden = false;
      responseBox.hidden = true;
      errorBox.hidden = true;

      try {
        const { endpoint, queryParams } = buildRequest();
        const result = await client.call(api, endpoint, {
          method,
          params: queryParams,
          paramStyle: paramStyle === 'query' ? 'query' : 'path',
        });

        respStatus.textContent = '✓ 200 OK';
        respStatus.className = 'tc-resp-status success';
        respCost.textContent = `💰 $${result.cost.toFixed(6)}`;
        respCache.textContent = result.cacheHit ? '⚡ Cache HIT (50% off)' : '🌐 Upstream';
        respLatency.textContent = `⏱ ${result.latencyMs}ms`;
        respJson.textContent = JSON.stringify(result.data, null, 2);
        responseBox.hidden = false;

        // Balance auto-decrements via axon:call-success event listener
      } catch (e) {
        let msg = e.message || 'Erro';
        if (e.status === 402) {
          msg = 'Saldo insuficiente. Deposite USDC pra continuar.';
        } else if (e.status === 401) {
          msg = 'API key inválida ou expirada.';
          client.clearKey();
          render();
        }
        errorMsg.textContent = msg;
        errorBox.hidden = false;
      } finally {
        runBtn.disabled = false;
        runLabel.hidden = false;
        runSpinner.hidden = true;
      }
    }

    // ─── Event bindings ────────────────────────────
    signupBtn.addEventListener('click', handleSignup);
    emailInput.addEventListener('keydown', e => { if (e.key === 'Enter') handleSignup(); });

    pasteBtn.addEventListener('click', handlePaste);
    pasteKeyInput.addEventListener('keydown', e => { if (e.key === 'Enter') handlePaste(); });

    runBtn.addEventListener('click', handleRun);

    root.querySelectorAll('.tc-ex-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const values = JSON.parse(btn.dataset.example);
        root.querySelectorAll('.tc-param').forEach(inp => {
          if (values[inp.dataset.paramName] !== undefined) {
            inp.value = values[inp.dataset.paramName];
          }
        });
      });
    });

    // Listen for cross-widget key changes
    window.addEventListener('axon:key-change', render);

    render();
  })();
</script>

<style>
  .trycall {
    margin: 2rem 0;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .tc-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.9rem 1.25rem;
    background: linear-gradient(135deg, rgba(124, 92, 255, 0.08), rgba(92, 138, 255, 0.05));
    border-bottom: 1px solid var(--border-soft);
    gap: 1rem;
    flex-wrap: wrap;
  }

  .tc-head-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .tc-badge {
    background: var(--accent-1);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    padding: 0.25em 0.6em;
    border-radius: 100px;
    letter-spacing: 0.1em;
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  .tc-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .tc-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 12px;
  }

  .tc-method {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--accent-2);
    padding: 0.2em 0.5em;
    background: var(--bg-tertiary);
    border-radius: var(--radius-sm);
  }

  .tc-api {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-tertiary);
    background: transparent;
    border: none;
    padding: 0;
  }

  .tc-desc {
    padding: 0 1.25rem;
    margin: 1rem 0 0 0;
    color: var(--text-tertiary);
    font-size: 14px;
  }

  /* Auth gate */
  .tc-auth-gate { padding: 1.5rem 1.25rem; }

  .tc-auth-box { text-align: center; }

  .tc-auth-box h4 {
    font-size: 1rem;
    margin: 0 0 0.4rem 0;
    color: var(--text-primary);
  }

  .tc-auth-box > p {
    color: var(--text-tertiary);
    font-size: 13px;
    margin: 0 0 1rem 0;
  }

  .tc-signup-row,
  .tc-paste-row {
    display: flex;
    gap: 0.5rem;
    max-width: 400px;
    margin: 0 auto;
  }

  .tc-divider {
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0.75rem 0;
  }

  .tc-signup-error {
    margin-top: 0.75rem;
    color: var(--error);
    font-size: 13px;
  }

  /* Form */
  .tc-form { padding: 1rem 1.25rem 1.25rem; }

  .tc-form-fields {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .tc-field { display: flex; flex-direction: column; gap: 0.4rem; }

  .tc-field label {
    font-size: 12px;
    color: var(--text-tertiary);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tc-input {
    background: var(--bg-code);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.65em 0.85em;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 14px;
    width: 100%;
    flex: 1;
    outline: none;
    transition: border-color 0.15s;
  }

  .tc-input:focus {
    border-color: var(--accent-1);
    box-shadow: 0 0 0 3px rgba(124, 92, 255, 0.15);
  }

  .tc-examples {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    align-items: center;
    font-size: 12px;
    color: var(--text-muted);
  }

  .tc-ex-btn {
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    color: var(--text-tertiary);
    font-size: 12px;
    padding: 0.25em 0.6em;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-family: var(--font-mono);
    transition: all 0.15s;
  }

  .tc-ex-btn:hover {
    color: var(--text-primary);
    border-color: var(--accent-1);
  }

  /* Buttons */
  .tc-btn {
    padding: 0.65em 1.2em;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 600;
    font-family: var(--font-body);
    border: 1px solid transparent;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
  }

  .tc-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .tc-btn-primary {
    background: var(--gradient);
    color: #fff;
  }

  .tc-btn-primary:hover:not(:disabled) {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .tc-btn-secondary {
    background: var(--bg-tertiary);
    color: var(--text-primary);
    border-color: var(--border);
  }

  .tc-btn-secondary:hover:not(:disabled) {
    border-color: var(--accent-1);
  }

  .tc-run-spinner svg {
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Actions */
  .tc-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border-soft);
  }

  .tc-status {
    font-size: 13px;
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .tc-balance-label {
    color: var(--text-muted);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .tc-balance-value {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--success);
  }

  .tc-balance-value.low { color: var(--warning); }

  /* Response */
  .tc-response {
    border-top: 1px solid var(--border-soft);
    background: var(--bg-code);
  }

  .tc-response-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    font-size: 12px;
    font-family: var(--font-mono);
    border-bottom: 1px solid var(--border-soft);
    background: rgba(34, 197, 94, 0.04);
  }

  .tc-resp-status.success { color: var(--success); font-weight: 600; }

  .tc-resp-body {
    margin: 0;
    padding: 1rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.5;
    max-height: 400px;
    overflow: auto;
    border: none;
    border-radius: 0;
    border-left: none;
    background: transparent;
  }

  .tc-resp-body code { background: transparent; border: none; padding: 0; }

  /* Error */
  .tc-error {
    padding: 0.9rem 1.25rem;
    background: rgba(239, 68, 68, 0.08);
    border-top: 1px solid var(--error);
    color: var(--error);
    font-size: 13px;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .tc-signup-row, .tc-paste-row { flex-direction: column; }
    .tc-head { padding: 0.75rem 1rem; }
    .tc-head-left { flex-wrap: wrap; }
  }
</style>
