---
interface Item {
  title: string;
  description: string;
  url: string;
  timeMinutes?: number;
  difficulty?: string;
}

interface Props {
  items: Item[];
  heading?: string;
}

const { items, heading = 'Próximos passos' } = Astro.props;
---

{items.length > 0 && (
  <section class="next-tutorial">
    <h2 class="nt-heading">{heading}</h2>
    <div class="nt-grid">
      {items.map(item => (
        <a href={item.url} class="nt-card">
          <div class="nt-card-body">
            <h3 class="nt-card-title">{item.title}</h3>
            <p class="nt-card-desc">{item.description}</p>
          </div>
          <div class="nt-card-meta">
            {item.timeMinutes && <span>⏱ {item.timeMinutes} min</span>}
            {item.difficulty && <span>◆ {item.difficulty}</span>}
            <span class="nt-arrow">→</span>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .next-tutorial {
    margin: 3rem 0 2rem 0;
  }

  .nt-heading {
    font-size: 1.3rem;
    margin-bottom: 1.25rem;
  }

  .nt-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  .nt-card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }

  .nt-card:hover {
    border-color: var(--accent-1);
    background: var(--bg-tertiary);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .nt-card-body { flex: 1; margin-bottom: 1rem; }

  .nt-card-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 0.4rem 0;
    line-height: 1.3;
  }

  .nt-card-desc {
    color: var(--text-tertiary);
    font-size: 14px;
    margin: 0;
    line-height: 1.5;
  }

  .nt-card-meta {
    display: flex;
    gap: 0.8rem;
    font-size: 12px;
    color: var(--text-muted);
    align-items: center;
  }

  .nt-arrow {
    margin-left: auto;
    color: var(--accent-1);
    font-size: 18px;
    font-weight: 700;
  }
</style>
