# ─── Core ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (Postgres) ────────────────────────────────
# Local docker: postgres://axon:axon@localhost:5432/axon
# Neon/Supabase: paste the full connection string
DATABASE_URL=postgres://axon:axon@localhost:5432/axon

# ─── Redis (cache) ──────────────────────────────────────
# Local docker: redis://localhost:6379
# Upstash: rediss://default:<pwd>@<host>:6379
REDIS_URL=redis://localhost:6379

# ─── Crypto ─────────────────────────────────────────────
# 32+ char hex string. Generate: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=change_me_to_32_hex_chars_minimum_abcdef1234567890

# Admin key for internal endpoints (user creation, registry, etc.)
# Generate: openssl rand -hex 32
ADMIN_API_KEY=change_me_admin_key_32_chars_minimum_abcdef1234

# ─── Base L2 / USDC ─────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
# USDC on Base mainnet
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Treasury wallet that receives deposits (your custodial controller)
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Wallet provider ────────────────────────────────────
# 'placeholder' = derive address from user UUID (dev/testnet only)
# 'cdp'         = Coinbase CDP sub-wallet per user (production)
# 'turnkey'     = Turnkey sub-org wallet (HSM-isolated)
# In production, =placeholder logs a loud warning at boot but still
# boots. Set to cdp/turnkey before going live or signups will hand
# out fake addresses that can't receive deposits.
WALLET_PROVIDER=placeholder
# Required if WALLET_PROVIDER=cdp
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE=
CDP_NETWORK_ID=base-mainnet
# Required if WALLET_PROVIDER=turnkey
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
TURNKEY_ORGANIZATION_ID=
TURNKEY_API_BASE_URL=https://api.turnkey.com

# ─── x402 native mode ───────────────────────────────────
# When true, /x402/v1/call/* accepts on-chain payments per request without
# a pre-funded wallet. Requires: bun add x402
ENABLE_X402_NATIVE=false

# ─── Upstream API keys (per provider) ───────────────────
# Add one line per API in your registry
UPSTREAM_KEY_OPENAI=
UPSTREAM_KEY_ANTHROPIC=
UPSTREAM_KEY_FIRECRAWL=
UPSTREAM_KEY_SERPAPI=
UPSTREAM_KEY_EXA=
UPSTREAM_KEY_TAVILY=
UPSTREAM_KEY_OPENWEATHER=
UPSTREAM_KEY_REPLICATE=
UPSTREAM_KEY_ELEVENLABS=
UPSTREAM_KEY_DEEPGRAM=
UPSTREAM_KEY_DEEPL=
UPSTREAM_KEY_APOLLO=
UPSTREAM_KEY_VOYAGE=
UPSTREAM_KEY_MINDEE=
UPSTREAM_KEY_IPINFO=
UPSTREAM_KEY_STABILITY=
UPSTREAM_KEY_TOGETHER=
UPSTREAM_KEY_BRAVE_SEARCH=
UPSTREAM_KEY_PERPLEXITY=
UPSTREAM_KEY_CARTESIA=
UPSTREAM_KEY_JINA=
UPSTREAM_KEY_RUNWAY=
UPSTREAM_KEY_BRIGHT_DATA=
UPSTREAM_KEY_HUNTER=
UPSTREAM_KEY_CLEARBIT=
UPSTREAM_KEY_NEYNAR=
UPSTREAM_KEY_ALCHEMY=

# ─── Alchemy (USDC deposit watcher) ─────────────────────
# Sign Alchemy webhooks with this secret (set in Alchemy dashboard)
ALCHEMY_WEBHOOK_SIGNING_KEY=
# Optional: gate deposit webhook with an extra shared token
DEPOSIT_WEBHOOK_TOKEN=

# ─── Observability ──────────────────────────────────────
# LOG_FORMAT: "json" (default in prod) or "pretty" (default in dev)
LOG_FORMAT=
# LOG_LEVEL: debug | info | warn | error
LOG_LEVEL=info
# Gate /metrics behind a bearer token in shared environments
METRICS_TOKEN=

# ─── Registry ───────────────────────────────────────────
# Override the registry/ folder location (default: resolved from src/)
AXON_REGISTRY_DIR=

# ─── CORS ───────────────────────────────────────────────
# Comma-separated origins allowed to call the API from a browser.
# Default is just the production frontend.
CORS_ALLOWED_ORIGINS=https://axon-5zf.pages.dev

# ─── Auth: Privy (embedded wallets) ─────────────────────
# Sign up at https://dashboard.privy.io. Free tier supports 1k MAU.
# JWT verification uses the public JWKS (no secret needed).
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ─── MercadoPago (Pix recharge) ─────────────────────────
# https://www.mercadopago.com.br/developers — production tokens start
# with APP_USR-..., sandbox with TEST-...
# In production, MP_WEBHOOK_SECRET is REQUIRED — without it,
# /v1/webhooks/mercadopago returns 503 instead of accepting payloads.
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
# Optional FX override; default 5.4 BRL/USD.
MP_FX_BRL_PER_USD=

# ─── Resend (transactional email) ───────────────────────
# https://resend.com — 3k/mo free tier
RESEND_API_KEY=
EMAIL_FROM=Axon <noreply@yourdomain.com>

# ─── Gemini (vision) ────────────────────────────────────
# https://aistudio.google.com — 1500 req/day free
GEMINI_API_KEY=

# ─── Voice (Deepgram STT + Cartesia/ElevenLabs TTS) ─────
# TTS routing: Cartesia tem prioridade quando CARTESIA_API_KEY existe;
# ElevenLabs serve como fallback (e ainda é necessário pra clonagem
# de voz e o picker de vozes da agente).
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
# Voice id default Cartesia (PT-BR). Catálogo em play.cartesia.ai/voices
CARTESIA_VOICE_ID=
ELEVENLABS_API_KEY=

# ─── NFT silent mint (agent ownership) ──────────────────
# Set all four to enable. Skip to disable — mints become no-ops.
# RPC URL determines chain (base-sepolia.org → testnet, mainnet.base.org → mainnet).
NFT_CONTRACT_ADDRESS=
NFT_MINTER_PRIVATE_KEY=
NFT_RPC_URL=
NFT_METADATA_BASE_URL=https://axon-kedb.onrender.com/agent-meta

# ─── Evolution (WhatsApp) ───────────────────────────────
# Shared Evolution instance for zero-config WhatsApp connect.
AXON_EVOLUTION_URL=
AXON_EVOLUTION_API_KEY=
